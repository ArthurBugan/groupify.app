{
  "expo": {
    "scheme": "groupify",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "ios": {
      "associatedDomains": [
        "applinks:groupify.dev",
        "applinks:groupify.dev"
      ],
      "bundleIdentifier": "com.groupifyapp",
      "appleTeamId": "UM6SZWPURL",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.groupifyapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ]
    ],
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "name": "groupifyapp",
    "slug": "groupify",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4d4f4c57-802b-4766-a035-07ad7cd3f21e"
      }
    },
    "owner": "arthurbugan",
    "version": "1.1.0"
  }
}
